&НаСервере
&После("ПриПечати")
Процедура ГСК5707_ПриПечати(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода)
	
	Если МассивОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПервыйОбъект = МассивОбъектов[0];
	Если ТипЗнч(ПервыйОбъект) <> Тип("ДокументСсылка.АктСверкиВзаиморасчетов") Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПервыйОбъект, "Номер, Дата, Контрагент");
	ТекстРеквизитов = СтрШаблон(НСтр("ru = 'Акт сверки № %1 от %2'"),
		Реквизиты.Номер,
		Формат(Реквизиты.Дата, "ДЛФ=D"));
	
	Если ЗначениеЗаполнено(Реквизиты.Контрагент) Тогда
		ТекстРеквизитов = ТекстРеквизитов + ", " + Строка(Реквизиты.Контрагент);
	КонецЕсли;
	
	Для Каждого ПечатнаяФорма Из КоллекцияПечатныхФорм Цикл
		Если ПечатнаяФорма.ИмяМакета <> "АктСверки" Тогда
			Продолжить;
		КонецЕсли;
		Если ПечатнаяФорма.ТабличныйДокумент = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ГСК5707_ОбщегоНазначения.ВставитьСтрокуВНачалоТабличногоДокумента(ПечатнаяФорма.ТабличныйДокумент, ТекстРеквизитов);
	КонецЦикла;
	
КонецПроцедуры
