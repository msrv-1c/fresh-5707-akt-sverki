// Идея 1Фреш #5707 — номер, дата и контрагент в печати акта сверки.

#Область ПрограммныйИнтерфейс

Функция ТекстБрендинга() Экспорт
	Возврат НСтр("ru = 'Создано на Конвейере 1С — https://gitsell.ru/1c'");
КонецФункции

Функция URLКонвейера() Экспорт
	Возврат "https://gitsell.ru/1c";
КонецФункции

Функция ПоказыватьБрендингВПечати() Экспорт
	Возврат Истина;
КонецФункции

Процедура ВставитьСтрокуВНачалоТабличногоДокумента(ТабличныйДокумент, Текст) Экспорт
	
	Если ТабличныйДокумент.ВысотаТаблицы = 0 Тогда
		Область = ТабличныйДокумент.Область(1, 1, 1, 1);
		Область.Текст = Текст;
		Возврат;
	КонецЕсли;
	
	ОбластьСдвига = ТабличныйДокумент.Область(1, 1, ТабличныйДокумент.ВысотаТаблицы, ТабличныйДокумент.ШиринаТаблицы);
	ТабличныйДокумент.ВставитьОбласть(ОбластьСдвига, , ТипСмещенияТабличногоДокумента.ПоВертикали);
	Шапка = ТабличныйДокумент.Область(1, 1, 1, ТабличныйДокумент.ШиринаТаблицы);
	Шапка.Очистить();
	
	ЯчейкаШапки = ТабличныйДокумент.Область(1, 1);
	ЯчейкаШапки.Текст = Текст;
	ЯчейкаШапки.Шрифт = Новый Шрифт(, 10, Истина);
	
КонецПроцедуры

#КонецОбласти
